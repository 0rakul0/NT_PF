# LLM defaults
PF_LLM_PROVIDER=auto
PF_OPENAI_MODEL=gpt-4.1-mini
PF_OPENAI_BASE_URL=https://api.openai.com/v1
PF_GROQ_MODEL=llama-3.3-70b-versatile
PF_OLLAMA_MODEL=llama3.2
PF_OLLAMA_BASE_URL=http://localhost:11434

# Para usar OpenAI, preencha uma das chaves abaixo e use PF_LLM_PROVIDER=openai.
# OPENAI_API_KEY=sua_chave_openai_aqui
# PF_OPENAI_API_KEY=sua_chave_openai_aqui

# Se quiser priorizar Groq sem depender da sessao do terminal, preencha a chave abaixo.
# GROQ_API_KEY=sua_chave_groq_aqui
# PF_GROQ_API_KEY=sua_chave_groq_aqui
